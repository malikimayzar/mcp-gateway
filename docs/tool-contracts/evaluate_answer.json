{
  "name": "evaluate_answer",
  "description": "Evaluate faithfulness of an answer against context",
  "endpoint": "http://localhost:8002",
  "timeout_seconds": 60,
  "input": {
    "answer": "string (required)",
    "context": "string (required)",
    "question": "string (required)"
  },
  "output": {
    "faithfulness_score": "float 0.0-1.0",
    "failure_mode": "string: none | unsupported_claims | insufficient_context",
    "has_failure": "bool",
    "supported_claims": "int",
    "total_claims": "int"
  },
  "errors": {
    "500": "evaluation failed",
    "400": "empty answer or context"
  }
}
