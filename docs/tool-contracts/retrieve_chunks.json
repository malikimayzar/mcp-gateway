{
  "name": "retrieve_chunks",
  "description": "Retrieve relevant chunks from rag-research service",
  "endpoint": "http://localhost:8003",
  "timeout_seconds": 10,
  "input": {
    "query": "string (required)",
    "top_k": "int (default: 5)",
    "method": "string: bm25 | dense | hybrid (default: bm25)"
  },
  "output": {
    "results": "array of {text, score, chunk_id}",
    "method": "string",
    "total": "int"
  },
  "errors": {
    "500": "retrieval failed",
    "400": "empty query or invalid method"
  }
}
